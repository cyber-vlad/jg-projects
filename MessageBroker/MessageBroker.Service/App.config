<?xml version="1.0" encoding="utf-8" ?>
<configuration>

  <appSettings>
    <add key="aspnet:UseTaskFriendlySynchronizationContext" value="true" />
  </appSettings>
	
  <system.web>
    <compilation debug="true" />
  </system.web>

	<system.serviceModel>
		
		<services>

			<service name="MessageBroker.Service.Services.PublisherService" behaviorConfiguration="enabled">
				<host>
					<baseAddresses>
						<add baseAddress="http://localhost:7001/publisher" />
					</baseAddresses>
				</host>

				<endpoint
					address="PublisherService"
					binding="webHttpBinding"
					behaviorConfiguration="webBehavior"
					contract="MessageBroker.Common.Interfaces.IPublisher" />

				<endpoint
					address="mex"
					binding="mexHttpBinding"
					contract="IMetadataExchange" />
			</service>

			<service name="MessageBroker.Service.Services.SubscriberService" behaviorConfiguration="disabled">
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:7002/subscriber" />
					</baseAddresses>
				</host>

				<endpoint
					address="SubscriberService"
					binding="netTcpBinding"
					bindingConfiguration="tcpBinding"
					contract="MessageBroker.Common.Interfaces.ISubscriber" />

				<endpoint
					address="mex"
					binding="mexTcpBinding"
					contract="IMetadataExchange" />
			</service>

			<service name="MessageBroker.Service.Services.TopicService" behaviorConfiguration="disabled">
				<host>
					<baseAddresses>
						<add baseAddress="net.pipe://localhost/topic" />
					</baseAddresses>
				</host>

				<endpoint
					address="TopicService"
					binding="netNamedPipeBinding"
					bindingConfiguration="netPipeBinding"
					contract="MessageBroker.Common.Interfaces.ITopic" />

				<endpoint
					address="mex"
					binding="mexNamedPipeBinding"
					contract="IMetadataExchange" />
				
			</service>

		</services>

		<bindings>

			<!--<customBinding>
				<binding name="jsonBinding">
					<webMessageEncoding />
					<httpTransport maxReceivedMessageSize="8192" manualAddressing="true" />
				</binding>
			</customBinding>-->
			
			<wsHttpBinding>
				<binding name="wsBinding"
						 maxReceivedMessageSize="8192"
						 sendTimeout="00:00:10"
						 receiveTimeout="00:00:10"
						 openTimeout="00:00:10"
						 closeTimeout="00:00:10">

					<reliableSession ordered="true"
									 enabled="true"
									 inactivityTimeout="00:01:00"/>

					<readerQuotas maxStringContentLength="8192"
								  maxDepth="32"/>
				</binding>
			</wsHttpBinding>

			<netNamedPipeBinding>
				<binding name="netPipeBinding"
						 maxReceivedMessageSize="8192"
						 sendTimeout="00:00:10"
						 receiveTimeout="00:00:10"
						 openTimeout="00:00:10"
						 closeTimeout="00:00:10">

					<readerQuotas maxStringContentLength="8192"
								  maxDepth="32"/>

				</binding>
			</netNamedPipeBinding>

			<netTcpBinding>
				<binding name="tcpBinding"
						 maxReceivedMessageSize="8192"
						 sendTimeout="00:00:10"
						 receiveTimeout="00:00:10"
						 openTimeout="00:00:10"
						 closeTimeout="00:00:10">

					<reliableSession ordered="true"
									 enabled="true" 
									 inactivityTimeout="00:01:00"/>

					<readerQuotas maxStringContentLength="8192"
								  maxDepth="32"/>
				</binding>
			</netTcpBinding>
		</bindings>

		<behaviors>
			<serviceBehaviors>

				<behavior name="enabled">
					<serviceMetadata httpGetEnabled="true"/>
					<serviceDebug includeExceptionDetailInFaults="true"/>
				</behavior>

				<behavior name="disabled">
					<serviceMetadata httpGetEnabled="false"/>
					<serviceDebug includeExceptionDetailInFaults="true"/>
				</behavior>

			</serviceBehaviors>
			
			<endpointBehaviors>
				<behavior name="webBehavior">
					<webHttp />
				</behavior>
			</endpointBehaviors>
			
		</behaviors>

	</system.serviceModel>

</configuration>