<?xml version="1.0" encoding="utf-8" ?>
<configuration>

  <appSettings>
    <add key="aspnet:UseTaskFriendlySynchronizationContext" value="true" />
  </appSettings>
	
  <system.web>
    <compilation debug="true" />
  </system.web>

	<system.serviceModel>
		
		<services>

			<service name="MessageBroker.Service.Services.PublisherService" >
				<host>
					<baseAddresses>
						<add baseAddress="http://localhost:7001/publisher" />
					</baseAddresses>
				</host>

				<endpoint
					address="PublisherService"
					binding="wsHttpBinding"
					bindingConfiguration="wsBinding"
					contract="MessageBroker.Common.Interfaces.IPublisher" />

				<endpoint
					address="mex"
					binding="mexHttpBinding"
					contract="IMetadataExchange" />
			</service>

			<service name="MessageBroker.Service.Services.SubscriberService" >
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:7002/subscriber" />
					</baseAddresses>
				</host>

				<endpoint
					address="SubscriberService"
					binding="netTcpBinding"
					bindingConfiguration="tcpBinding"
					contract="MessageBroker.Common.Interfaces.ISubscriber" />

				<endpoint
					address="mex"
					binding="mexTcpBinding"
					contract="IMetadataExchange" />
			</service>

			<service name="MessageBroker.Service.Services.TopicService">
				<host>
					<baseAddresses>
						<add baseAddress="net.pipe://localhost/topic" />
					</baseAddresses>
				</host>

				<endpoint
					address="TopicService"
					binding="netNamedPipeBinding"
					bindingConfiguration="netPipeBinding"
					contract="MessageBroker.Common.Interfaces.ITopic" />

				<endpoint
					address="mex"
					binding="mexNamedPipeBinding"
					contract="IMetadataExchange" />
				
			</service>

		</services>

		<bindings>
			
			<wsHttpBinding>
				<binding name="wsBinding"
						 maxReceivedMessageSize="65536"
						 sendTimeout="00:01:00"
						 receiveTimeout="00:01:00"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00">
					
					<reliableSession ordered="true" 
									 enabled="true" 
									 inactivityTimeout="00:10:00" />
				</binding>
			</wsHttpBinding>
			
			<netNamedPipeBinding>
				<binding name="netPipeBinding"
						 maxReceivedMessageSize="65536"
						 maxConnections="50">
				</binding>
			</netNamedPipeBinding>

			<netTcpBinding>
				<binding name="tcpBinding">
					
					<reliableSession ordered="true" 
									 inactivityTimeout="00:05:00" 
									 enabled="true"/>
					
					<readerQuotas maxStringContentLength="8192" 
								  maxDepth="16"/>
				</binding>
			</netTcpBinding>
		</bindings>
		
		<behaviors>
			<serviceBehaviors>

				<behavior>
					<serviceMetadata httpGetEnabled="false"/>
					<serviceDebug includeExceptionDetailInFaults="true"/>
				</behavior>
				
			</serviceBehaviors>
		</behaviors>

	</system.serviceModel>

</configuration>