<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup> 
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
	</startup>

	<system.serviceModel>
		
        <bindings />

		<client>
			<endpoint address="http://localhost:7001/publisher/PubliserService" binding="wsHttpBinding"
                 contract="IPublisher">
			</endpoint>

			<endpoint address="net.tcp://localhost:7002/subscriber/SubscriberService" binding="netTcpBinding"
                 contract="ISubscriber">
			</endpoint>

			<endpoint address="net.pipe://localhost/topic/TopicService" binding="netNamedPipeBinding"
                 contract="ITopic">
			</endpoint>
		</client>
		
	</system.serviceModel>
	
</configuration>